# .editorconfig
#
# AGENT CONTEXT: EditorConfig ensures consistent formatting across editors
# and operating systems. Supported natively by most editors; VS Code needs
# the "EditorConfig for VS Code" extension.
#
# This file applies to the entire monorepo. Individual packages should NOT
# override these settings — consistency across the repo is the goal.
#
# Spec: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
# Markdown: preserve trailing spaces (two spaces = line break in MD spec)
trim_trailing_whitespace = false

[Makefile]
# Make requires tabs for recipe indentation — do not change
indent_style = tab

[*.{yaml,yml}]
indent_size = 2

[*.json]
indent_size = 2

[*.toml]
indent_size = 2

[pnpm-lock.yaml]
# Lock files are auto-generated — editors should not reformat them
trim_trailing_whitespace = false
insert_final_newline = false
