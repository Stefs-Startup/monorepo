# =============================================================================
# AGENT CONTEXT: This .gitignore covers the full monorepo.
# Individual workspace packages should NOT have their own .gitignore files
# unless they have package-specific ignores not covered here.
# Keep this file as the single source of truth for ignored paths.
# =============================================================================


# -----------------------------------------------------------------------------
# Node / pnpm
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log

# pnpm lock is intentionally TRACKED — it ensures reproducible installs across
# all environments (local, CI, production). Never add pnpm-lock.yaml here.

# Build outputs — each workspace builds into its own dist/ or .next/ etc.
dist/
build/
out/
.next/
.nuxt/
.output/
.cache/

# TypeScript incremental compilation cache
*.tsbuildinfo


# -----------------------------------------------------------------------------
# Environment / secrets
# Never commit .env files. Use .env.example to document required variables.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -----------------------------------------------------------------------------
# OS / Editor artifacts
# These should ideally live in a global ~/.gitignore_global but are included
# here as a safety net for contributors who haven't configured that.
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VSCode — settings are intentionally NOT ignored so shared config is checked in
.vscode/extensions.json
# (keep .vscode/settings.json and .vscode/launch.json tracked)

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo


# -----------------------------------------------------------------------------
# Test / Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/


# -----------------------------------------------------------------------------
# Infrastructure / Deployment
# AGENT: infra/ directory lives at repo root (see CMP-12).
# Terraform state is sensitive — never commit it.
# -----------------------------------------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Rust / JVM build outputs
target/
**/target/
.gradle/
**/.gradle/
