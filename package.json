{
  "name": "cmp-root",
  "version": "0.0.0",

  "private": true,

  "description": "Company of One — monorepo root. All apps, packages, and infrastructure live here.",

  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },

  "scripts": {
    "build":   "pnpm -r build",
    "dev":     "pnpm -r --parallel dev",
    "lint":    "pnpm -r lint",
    "test":    "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean":   "pnpm -r clean && rm -rf node_modules"
  }
}
